{
  "name": "kalas-size-wizard",
  "version": "1.0.0",
  "description": "Size recommendation calculator for Kalas Sportswear cycling apparel",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "demo": "node demo.mjs",
    "serve": "npx serve .",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "keywords": [
    "kalas",
    "cycling",
    "apparel",
    "size",
    "sizing"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  }
}
